<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">
  <Appenders>
    <Console name="Console" target="SYSTEM_OUT">
      <PatternLayout pattern="%level{length=5} | %d{yyyy-MM-dd HH:mm:ss} | [%t] %logger{1} (%F:%M:%L) - %msg%n"/>
    </Console>
    <RollingFile name="File" fileName="testlog/test.log"
                 filePattern="testlog/test-%d{yyyy-MM-dd}-%i.log">
      <PatternLayout pattern="%level{length=5} | %d{yyyy-MM-dd HH:mm:ss} | [%t] %logger{1} (%F:%M:%L) - %msg%n"/>
      <Policies>
        <SizeBasedTriggeringPolicy size="10MB"/>
      </Policies>
      <DefaultRolloverStrategy max="10"/>
    </RollingFile>
  </Appenders>
  <Loggers>
    <Root level="INFO">
      <AppenderRef ref="Console"/>
      <AppenderRef ref="File"/>
    </Root>
  </Loggers>
</Configuration>
